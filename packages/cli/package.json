{
  "name": "@xrmforge/cli",
  "version": "0.1.0",
  "description": "CLI for XrmForge - TypeScript type generator for Dynamics 365",
  "keywords": [
    "dynamics-365",
    "typescript",
    "xrm",
    "dataverse",
    "cli",
    "code-generation"
  ],
  "license": "MIT",
  "author": "XrmForge Contributors",
  "homepage": "https://github.com/juergenbeck/XrmForge/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/juergenbeck/XrmForge.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/juergenbeck/XrmForge/issues"
  },
  "type": "module",
  "bin": {
    "xrmforge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xrmforge/typegen": "workspace:*",
    "@azure/identity": "^4.6.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
