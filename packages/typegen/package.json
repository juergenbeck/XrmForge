{
  "name": "@xrmforge/typegen",
  "version": "0.1.0",
  "description": "TypeScript declaration generator for Dynamics 365 / Dataverse",
  "keywords": [
    "dynamics-365",
    "typescript",
    "xrm",
    "dataverse",
    "type-generator",
    "declaration-files"
  ],
  "license": "MIT",
  "author": "XrmForge Contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "fast-xml-parser": "^5.5.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@types/xrm": ">=9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
