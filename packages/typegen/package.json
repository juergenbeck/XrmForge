{
  "name": "@xrmforge/typegen",
  "version": "0.16.0",
  "description": "TypeScript declaration generator for Dynamics 365 / Dataverse",
  "keywords": [
    "dynamics-365",
    "typescript",
    "xrm",
    "dataverse",
    "type-generator",
    "declaration-files"
  ],
  "license": "MIT",
  "author": "XrmForge Contributors",
  "homepage": "https://github.com/juergenbeck/XrmForge/tree/main/packages/typegen",
  "repository": {
    "type": "git",
    "url": "https://github.com/juergenbeck/XrmForge.git",
    "directory": "packages/typegen"
  },
  "bugs": {
    "url": "https://github.com/juergenbeck/XrmForge/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "MIGRATION.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node scripts/copy-docs.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist docs"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "fast-xml-parser": "^5.5.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@types/xrm": ">=9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
