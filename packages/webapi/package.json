{
  "name": "@xrmforge/webapi",
  "version": "0.1.0",
  "description": "Type-safe Xrm.WebApi client with query builder for Dynamics 365",
  "keywords": [
    "dynamics-365",
    "typescript",
    "xrm",
    "webapi",
    "dataverse",
    "odata",
    "query-builder"
  ],
  "license": "MIT",
  "author": "XrmForge Contributors",
  "homepage": "https://github.com/juergenbeck/XrmForge/tree/main/packages/webapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/juergenbeck/XrmForge.git",
    "directory": "packages/webapi"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@types/xrm": ">=9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
