{
  "name": "@xrmforge/dataverse-client",
  "version": "0.1.0",
  "description": "Browser-first Dataverse Web API client: cookie-based fetch transport and retrieveAll paging",
  "keywords": [
    "dynamics-365",
    "dataverse",
    "odata",
    "web-api",
    "typescript",
    "fetch",
    "browser"
  ],
  "license": "MIT",
  "author": "XrmForge Contributors",
  "homepage": "https://github.com/juergenbeck/XrmForge/tree/main/packages/dataverse-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/juergenbeck/XrmForge.git",
    "directory": "packages/dataverse-client"
  },
  "bugs": {
    "url": "https://github.com/juergenbeck/XrmForge/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xrmforge/dataverse-core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@types/xrm": ">=9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
