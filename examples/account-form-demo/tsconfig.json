{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "typeRoots": ["../../packages/typegen/node_modules/@types"],
    "types": ["xrm"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@xrmforge/helpers": ["../../packages/helpers/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "generated/**/*.ts"
  ]
}
